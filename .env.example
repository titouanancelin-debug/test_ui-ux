# =====================================================================
# Exemple de configuration. Copier en .env et remplir avec vos clés.
#   cp .env.example .env
# Le fichier .env est ignoré par git (voir .gitignore) : il ne sera
# JAMAIS commité. Ne partagez jamais ces clés.
# =====================================================================

# --- Alpaca (Paper Trading) ---
# Générez vos clés sur https://app.alpaca.markets/ (compte Paper)
ALPACA_API_KEY=votre_cle_ici
ALPACA_API_SECRET=votre_secret_ici
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Telegram (notifications de signaux) ---
# 1. Ouvre Telegram → cherche @BotFather → /newbot → copie le token
# 2. Envoie un message à ton bot puis va sur :
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    et copie le "id" dans "chat"
TELEGRAM_BOT_TOKEN=123456:ABC-votre-token-ici
TELEGRAM_CHAT_ID=123456789

# --- Paramètres stratégie (optionnels, valeurs par défaut dans config.py) ---
CAPITAL=200
RISK_PERCENT=1.5
RR_RATIO=2.5
